<footer class="footer workshop-footer">
  <div class="workshop-footer-bar">
    <div class="workshop-footer-left">
      <img src="{{uiRootPath}}/img/logo-redhat.svg" alt="Red Hat" class="workshop-footer-logo" width="120" height="28">
      <span class="workshop-footer-lab-label">Hybrid Mesh AI Workshop</span>
    </div>
    <div class="workshop-footer-right">
      <span class="workshop-footer-lab">Lab user: <strong id="footer-user-name">guest</strong></span>
      <span class="workshop-footer-sep" aria-hidden="true">|</span>
      <a id="footer-register-link" href="https://workshop-registration.%HUB_DOMAIN%/?USER_NAME=%USER_NAME%" class="workshop-footer-register">Registration</a>
    </div>
  </div>
</footer>
<div id="workshop-terminal-panel" class="workshop-terminal-panel" aria-hidden="true" role="dialog" aria-label="Showroom terminal">
  <div class="workshop-terminal-toolbar">
    <span class="workshop-terminal-title"><i class="fa fa-terminal"></i> Showroom terminal <code>oc</code></span>
    <div class="workshop-terminal-actions">
      <button type="button" id="workshop-terminal-newtab" class="workshop-terminal-action" title="Open terminal in new tab">
        <i class="fa fa-external-link"></i>
      </button>
      <button type="button" id="workshop-terminal-close" class="workshop-terminal-action" title="Close terminal" aria-label="Close terminal">
        <i class="fa fa-times"></i>
      </button>
    </div>
  </div>
  <iframe id="workshop-terminal-frame" class="workshop-terminal-frame" title="Integrated oc terminal" loading="lazy"></iframe>
</div>
<script src="{{{uiRootPath}}}/js/workshop-runtime.js"></script>
<script src="{{{uiRootPath}}}/js/progress-tracker.js"></script>
