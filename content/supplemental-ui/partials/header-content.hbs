<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item navbar-logo" href="https://www.redhat.com" target="_blank" rel="noopener noreferrer" title="Red Hat">
        <img src="{{uiRootPath}}/img/logo-redhat.svg" alt="Red Hat" class="navbar-logo-img" width="140" height="33">
      </a>
      <div class="workshop-brand-text">
        <a class="navbar-item site-title" href="../{{page.component.name}}/00-index.html">{{site.title}}</a>
        <span class="workshop-event-tag">OpenShift Commons Gathering — Buenos Aires 2026</span>
      </div>
    </div>
    <div id="topbar-nav" class="navbar-menu">
      <div class="navbar-end">
        <div class="navbar-item workshop-navbar-links">
          <a id="link-developer-hub" href="#" target="_blank" rel="noopener noreferrer" class="workshop-quick-link" title="Developer Hub">
            <i class="fa fa-th-large"></i> Dev Hub
          </a>
          <a id="link-console" href="#" target="_blank" rel="noopener noreferrer" class="workshop-quick-link" title="OpenShift Console">
            <i class="fa fa-cube"></i> Console
          </a>
          <a id="link-gitea" href="#" target="_blank" rel="noopener noreferrer" class="workshop-quick-link" title="Gitea">
            <i class="fa fa-code-fork"></i> Gitea
          </a>
          <a id="link-devspaces" href="#" target="_blank" rel="noopener noreferrer" class="workshop-quick-link" title="DevSpaces">
            <i class="fa fa-cloud"></i> DevSpaces
          </a>
          <span class="workshop-navbar-sep" aria-hidden="true"></span>
          <span class="workshop-lang-bar" aria-label="Language">
            <a href="../en/{{page.file.srcStem}}.html">EN</a>
            <span class="workshop-lang-sep">|</span>
            <a href="../es/{{page.file.srcStem}}.html">ES</a>
          </span>
          <span class="workshop-navbar-sep" aria-hidden="true"></span>
          <a id="workshop-register-link" href="https://workshop-registration.%HUB_DOMAIN%/?USER_NAME=%USER_NAME%" class="workshop-quick-link workshop-quick-link--register" title="Workshop registration">
            <i class="fa fa-id-badge"></i> <span id="register-link-label">Register</span>
          </a>
          <span class="workshop-navbar-sep" aria-hidden="true"></span>
          <span id="user-badge" class="workshop-user-badge-nav">
            <i class="fa fa-user"></i>
            <span id="user-badge-name">guest</span>
          </span>
          <div id="vars-edit-panel" class="workshop-vars-edit" style="display:none;">
            <label for="user-name-input">User:</label>
            <input type="text" id="user-name-input" placeholder="user1">
            <button type="button" id="vars-save">Save</button>
            <button type="button" id="vars-cancel-edit">Cancel</button>
          </div>
          <button type="button" id="vars-edit-btn" title="Change lab user" class="workshop-vars-edit-btn">
            <i class="fa fa-pencil"></i>
          </button>
        </div>
      </div>
    </div>
  </nav>
</header>
